PORT=8000
WORKERS=6
SUPERUSER_EMAIL=admin@xenovrastream.io
SUPERUSER_PASS=change-me
ACCESS_TOKEN_EXPIRE_IN_SECS=86400
REFRESH_TOKEN_EXPIRE_IN_DAYS=14
SECRET_KEY=change-me-to-something-random
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Calls per minute allowed per bot token. Every extra bot on a storage lifts the
# real ceiling, which is what makes playback smooth under load.
TELEGRAM_RATE_LIMIT=18

DATABASE_USER=xenovrastream
DATABASE_PASSWORD=change-me
DATABASE_NAME=xenovrastream
DATABASE_HOST=db
DATABASE_PORT=5432

# --- streaming ------------------------------------------------------------

# Uploads, ffmpeg scratch space and the segment cache. Needs room for the
# largest source file plus its renditions while a job runs.
WORK_DIR=/var/lib/xenovrastream

# Segment cache ceiling in MB. Bigger is better: a cached segment costs Telegram
# nothing, an uncached one costs two rate-limited API calls.
CACHE_MAX_MB=4096

# HLS segment length in seconds. Shorter seeks faster but multiplies the number
# of Telegram messages and API calls per minute of playback.
SEGMENT_SECS=6

# Segments pushed to Telegram at once during a job.
UPLOAD_CONCURRENCY=4

# x264 speed/quality tradeoff: ultrafast · superfast · veryfast · faster · fast
# · medium · slow. `medium` buys ~15% bitrate for roughly 3x the transcode time.
X264_PRESET=veryfast
